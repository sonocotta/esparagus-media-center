{
    "name": "esparagus-audio-brick",
    "version": "$commitid",
    "home_assistant_domain": "slim_player",
    "funding_url": "https://esphome.io/guides/supporters.html",
    "new_install_prompt_erase": true,
    "new_install_improv_wait_time": 20,
    "builds": [
        {
            "chipFamily": "ESP32",
            "parts": [
                {
                    "path": "binaries/I2S-4MFlash-sdkconfig.esp32-16bit/bootloader-$commitid.bin",
                    "offset": "0x1000"
                },
                {
                    "path": "binaries/I2S-4MFlash-sdkconfig.esp32-16bit/partition-table-$commitid.bin",
                    "offset": "0x8000"
                },
                {
                    "path": "binaries/settings/common-esp-nvs.bin",
                    "offset": "0x9000"
                },
                {
                    "path": "binaries/I2S-4MFlash-sdkconfig.esp32-16bit/ota_data_initial-$commitid.bin",
                    "offset": "0xd000"
                },
                {
                    "path": "binaries/I2S-4MFlash-sdkconfig.esp32-16bit/recovery-$commitid.bin",
                    "offset": "0x10000"
                },
                {
                    "path": "binaries/I2S-4MFlash-sdkconfig.esp32-16bit/squeezelite-$commitid.bin",
                    "offset": "0x150000"
                },
                {
                    "path": "binaries/settings/audio-brick-settings.bin",
                    "offset": "0x3f0000"
                }
            ]
        }
    ],
    "manifest_name": "manifest-esparagus-audio-brick-16-latest.json"
}